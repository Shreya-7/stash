---
import Base from './Base.astro';
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
const author = await getEntry(post.data.author);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title={post.data.title} description={post.data.excerpt}>
  <article class="post">
    <header class="post__header">
      <h1 class="post__title">{post.data.title}</h1>
      <div class="post__byline">
        <span>{author?.data.name}</span>
        <span>·</span>
        <span>{fmt(post.data.date)}</span>
        <span>·</span>
        <a href={`/categories/${post.data.category}/`} class="tag">
          {post.data.category}{post.data.subcategory ? ` / ${post.data.subcategory}` : ''}
        </a>
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
