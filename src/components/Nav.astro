---
import { CATEGORIES } from '../content.config';
import { u } from '../lib/url';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === u() ? path === u() : path.startsWith(href);
---
<nav class="nav">
  <a href={u()} class="nav__brand">stash</a>
  <div class="nav__links">
    {CATEGORIES.map((c) => (
      <a href={u(`categories/${c}/`)} class:list={[{ 'is-active': isActive(u(`categories/${c}/`)) }]}>
        {c}
      </a>
    ))}
    <a href={u('authors/shreya/')} class:list={[{ 'is-active': isActive(u('authors/shreya/')) }]}>shreya</a>
    <a href={u('authors/abhishek/')} class:list={[{ 'is-active': isActive(u('authors/abhishek/')) }]}>abhishek</a>
  </div>
</nav>
